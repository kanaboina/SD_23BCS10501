        <mxCell id="DpTUUDj_igMBGKd7A-jV-106" parent="1" style="swimlane;startSize=0;" value="aaa" vertex="1">
          <mxGeometry height="1880" width="1030" x="370" y="-1350" as="geometry" />
        </mxCell>
        <mxCell id="DpTUUDj_igMBGKd7A-jV-1" parent="DpTUUDj_igMBGKd7A-jV-106" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=21;" value="Design a e-commerce system with following requirements&lt;div&gt;1.User login service&lt;/div&gt;&lt;div&gt;2.search service&amp;nbsp;&lt;/div&gt;&lt;div&gt;3.product catalog service&amp;nbsp;&lt;/div&gt;&lt;div&gt;4.cart service&lt;/div&gt;&lt;div&gt;5.order status service&amp;nbsp;&lt;/div&gt;&lt;div&gt;6.check out service&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="800" x="60" y="10" as="geometry" />
        </mxCell>
        <mxCell id="DpTUUDj_igMBGKd7A-jV-2" parent="DpTUUDj_igMBGKd7A-jV-106" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=19;" value="Functional Requirements-&amp;gt;&lt;div&gt;1) User should be able to login.&lt;/div&gt;&lt;div&gt;2) User should be able to search for products.&lt;/div&gt;&lt;div&gt;3)User should be able to see whether product is available.&lt;/div&gt;&lt;div&gt;4) User should be able to add products to the cart.&lt;/div&gt;&lt;div&gt;6)User should be able to checkout and do payment.&lt;/div&gt;&lt;div&gt;5) User should get notified about payment and order status.&lt;/div&gt;" vertex="1">
          <mxGeometry height="310" width="320" x="40" y="240" as="geometry" />
        </mxCell>
        <mxCell id="DpTUUDj_igMBGKd7A-jV-9" parent="DpTUUDj_igMBGKd7A-jV-106" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=19;" value="Non-Functional-Requirements-&amp;gt;&lt;div&gt;1)Search products service should be able to display products with 100ms latency.&lt;/div&gt;&lt;div&gt;2)Products images should load fast.&lt;/div&gt;&lt;div&gt;3) Login service and payment service&amp;nbsp; should be scalable for 1 million users.&lt;/div&gt;&lt;div&gt;4) Users should be notified of their order status .&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
