        <mxCell id="aWkcEURjoyIysUinpvPr-82" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Functional Requirements&lt;/font&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Search Functionality: The user must be able to discover events using filters such as the Event Title, the City/Location, and the specific Date of the show.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Event Information Display: The user must be able to view comprehensive details for a specific event, including the No of Seats (available vs. occupied), a detailed Description, and Metadata (cast, duration, language, ratings).&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Booking Execution: The system must allow a user to select a seat and complete a transaction to Book a Ticket.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="300" width="400" x="-100" y="595" as="geometry" />
        </mxCell>
        <mxCell id="aWkcEURjoyIysUinpvPr-83" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;Non Functional Requirements&lt;/span&gt;&lt;br&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;Target Scale: The system must be designed to support 100 Million Daily Active Users (DAU).&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;High Availability: When users are searching or viewing an event, the system must prioritize being &quot;always online&quot; (High Availability). It is better to show slightly older data than to show an error page.&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;background-color: transparent; font-size: 20px;&quot;&gt;High Consistency: When a user is booking a specific ticket, the system must be Highly Consistent. Two people should never be able to book the exact same seat at the exact same time.&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="470" x="-130" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="aWkcEURjoyIysUinpvPr-84" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;API Designs&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;POST /api/v1/auth/signup&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;POST /api/v1/auth/login&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;GET&amp;nbsp; /api/v1/users/me&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;POST /api/v1/events&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;GET&amp;nbsp; /api/v1/events/{eventId}&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;GET&amp;nbsp; /api/v1/events?location={location}&amp;amp;date={date}&amp;amp;page={page}&amp;amp;limit={limit}&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;GET&amp;nbsp; /api/v1/search?q={query}&amp;amp;location={location}&amp;amp;date={date}&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;POST /api/v1/bookings&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;POST /api/v1/bookings/{bookingId}/confirm&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;GET&amp;nbsp; /api/v1/bookings/my?page={page}&amp;amp;limit={limit}&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;POST /api/v1/payments&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;POST /api/v1/payments/webhook&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="740" x="-250" y="1498" as="geometry" />
        </mxCell>
        <mxCell id="gawOs21RS_9gigVL7ljp-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;users (&lt;/div&gt;&lt;div&gt;&amp;nbsp; id BIGINT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; name VARCHAR(100),&lt;/div&gt;&lt;div&gt;&amp;nbsp; email VARCHAR(100) UNIQUE,&lt;/div&gt;&lt;div&gt;&amp;nbsp; password_hash TEXT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; created_at TIMESTAMP&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;events (&lt;/div&gt;&lt;div&gt;&amp;nbsp; id BIGINT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; title VARCHAR(255),&lt;/div&gt;&lt;div&gt;&amp;nbsp; location VARCHAR(100),&lt;/div&gt;&lt;div&gt;&amp;nbsp; date TIMESTAMP,&lt;/div&gt;&lt;div&gt;&amp;nbsp; total_seats INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; available_seats INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; created_at TIMESTAMP&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;seats (&lt;/div&gt;&lt;div&gt;&amp;nbsp; id BIGINT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; event_id BIGINT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; seat_number INT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; status ENUM(&#39;AVAILABLE&#39;, &#39;LOCKED&#39;, &#39;BOOKED&#39;),&lt;/div&gt;&lt;div&gt;&amp;nbsp; UNIQUE(event_id, seat_number)&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;bookings (&lt;/div&gt;&lt;div&gt;&amp;nbsp; id BIGINT PRIMARY KEY,&lt;/div&gt;&lt;div&gt;&amp;nbsp; user_id BIGINT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; event_id BIGINT,&lt;/div&gt;&lt;div&gt;&amp;nbsp; status ENUM(&#39;PENDING&#39;, &#39;CONFIRMED&#39;, &#39;FAILED&#39;),&lt;/div&gt;&lt;div&gt;&amp;nbsp; total_amount DECIMAL,&lt;/div&gt;&lt;div&gt;&amp;nbsp; created_at TIMESTAMP&lt;/div&gt;&lt;div&gt;)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="820" x="880" y="1850" as="geometry" />
        </mxCell>
